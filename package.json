{
  "name": "smailee",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build && npm run build:worker",
    "build:worker": "esbuild src/server/worker.ts --bundle --platform=node --target=node20 --format=cjs --outfile=dist/worker.js --external:@prisma/client --external:.prisma --log-level=warning",
    "start": "next start",
    "postinstall": "prisma generate",
    "smoke": "tsx scripts/smoke.ts",
    "check": "tsc --noEmit && npm run smoke && npm run build",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:deploy": "prisma migrate deploy",
    "worker": "tsx src/server/worker.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "exceljs": "^4.4.0",
    "imapflow": "^1.4.7",
    "jsonwebtoken": "^9.0.3",
    "mailparser": "^3.9.14",
    "next": "16.2.10",
    "nodemailer": "^9.0.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "esbuild": "^0.28.1",
    "playwright": "^1.61.1",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "tsx": "^4.22.5",
    "typescript": "^5"
  }
}
