// Smailee — схема БД
// Postgres (dev: локальный smailee_dev; prod: Amvera Postgres через DATABASE_URL)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Пользователь (владелец аккаунта, self-serve) ──
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  companyName  String?
  createdAt    DateTime @default(now())

  // Онбординг: чем занимается бизнес клиента (AI изучает это)
  websiteUrl   String?
  offer        String?  // ценностное предложение / оффер
  targetAudience String? // портрет клиента, кого ищем

  senders    Sender[]
  contacts   Contact[]
  campaigns  Campaign[]
  leads      Lead[]      @relation("UserLeads")
  templates  EmailTemplate[]
  suppressions Suppression[]
}

// ── Отправитель (домен/почта, с которой шлём) ──
model Sender {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromEmail  String
  fromName   String
  domain     String
  // статус проверки DNS
  spfOk      Boolean  @default(false)
  dkimOk     Boolean  @default(false)
  dmarcOk    Boolean  @default(false)
  verified   Boolean  @default(false)
  // прогрев (warm-up): текущий дневной лимит и счётчик
  warmupDay      Int    @default(0)   // сколько дней идёт прогрев
  dailyLimit     Int    @default(30)  // текущий лимит писем в день
  sentToday      Int    @default(0)
  sentTodayDate  DateTime?
  createdAt  DateTime @default(now())

  campaigns  Campaign[]
}

// ── Контакт из базы клиента ──
model Contact {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  email      String
  name       String?
  company    String?
  segment    String?  // сегмент/ниша
  meta       Json?
  status     ContactStatus @default(ACTIVE)
  // результат валидации email при загрузке
  emailValid Boolean  @default(true)
  createdAt  DateTime @default(now())

  messages   Message[]

  @@unique([userId, email])
  @@index([userId, segment])
}

enum ContactStatus {
  ACTIVE
  BOUNCED
  UNSUBSCRIBED
  INVALID
  COMPLAINED
}

// ── Библиотека HTML-шаблонов писем ──
model EmailTemplate {
  id         String   @id @default(cuid())
  userId     String?  // null = системный (пресет), иначе — пользовательский
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  category   String   // announce | digest | promo | outreach | custom
  subject    String
  html       String   // HTML-тело с переменными {{name}} и т.п.
  isPreset   Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([userId])
}

// ── Кампания рассылки ──
model Campaign {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  senderId   String?
  sender     Sender?  @relation(fields: [senderId], references: [id])
  name       String
  subject    String
  body       String   // текст/HTML письма (основной вариант / вариант A)
  isHtml     Boolean  @default(false)
  // A/B: необязательный второй вариант
  subjectB   String?
  bodyB      String?
  abEnabled  Boolean  @default(false)
  segment    String?
  status     CampaignStatus @default(DRAFT)
  scheduledAt DateTime?      // отложенный запуск (send_at)
  // follow-up: доп. письмо, если нет ответа через N дней
  followupEnabled Boolean @default(false)
  followupDays    Int     @default(3)
  followupSubject String?
  followupBody    String?
  createdAt  DateTime @default(now())
  startedAt  DateTime?

  messages   Message[]
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  QUEUED
  SENDING
  SENT
  PAUSED
}

// ── Каждое отправленное письмо = отдельная запись со статусом ──
model Message {
  id          String   @id @default(cuid())
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contactId   String
  contact     Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  subject     String
  body        String
  isHtml      Boolean  @default(false)
  variant     String   @default("A")  // A | B (для A/B)
  step        Int      @default(0)     // 0 = основное, 1+ = follow-up
  status      MessageStatus @default(PENDING)
  providerMessageId String?
  sentAt      DateTime?
  deliveredAt DateTime?
  openedAt    DateTime?
  clickedAt   DateTime?
  repliedAt   DateTime?
  followupSentAt DateTime?  // когда отправлен follow-up для этого письма
  error       String?
  createdAt   DateTime @default(now())

  events      Event[]
  thread      ReplyMessage[]
  lead        Lead?

  @@index([campaignId, status])
}

enum MessageStatus {
  PENDING
  QUEUED
  SENT
  DELIVERED
  OPENED
  CLICKED
  REPLIED
  BOUNCED
  FAILED
}

// ── Сырые события (open/click/bounce/reply) для аналитики ──
model Event {
  id        String   @id @default(cuid())
  messageId String
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  type      String   // open | click | bounce | reply | delivered | complaint
  payload   Json?
  createdAt DateTime @default(now())

  @@index([messageId, type])
}

// ── Диалог: входящие ответы + AI-ответы (email-тред) ──
model ReplyMessage {
  id         String   @id @default(cuid())
  messageId  String
  message    Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  direction  String   // inbound (от клиента) | outbound (AI-ответ)
  subject    String?  // тема письма (Re: ...)
  fromEmail  String?
  toEmail    String?
  body       String
  isAi       Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([messageId])
}

// ── Квалифицированный лид ──
model Lead {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation("UserLeads", fields: [userId], references: [id], onDelete: Cascade)
  messageId    String   @unique
  message      Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  qualification LeadQualification @default(UNKNOWN)
  summary      String?
  pushedToCrm  Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([userId, qualification])
}

enum LeadQualification {
  HOT
  COLD
  IRRELEVANT
  UNKNOWN
}

// ── Suppression-список: отписки, жалобы, невалидные (не слать) ──
model Suppression {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  email     String
  reason    String   // unsubscribed | complained | bounced | manual
  createdAt DateTime @default(now())

  @@unique([userId, email])
  @@index([userId])
}

// ── Заявка с лендинга (лид-форма / запись на демо) ──
model LandingLead {
  id        String   @id @default(cuid())
  name      String
  email     String
  messenger String?
  company   String?
  source    String?  // utm/канал
  createdAt DateTime @default(now())
}
