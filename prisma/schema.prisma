// Smailee — схема БД
// Postgres (dev: локальный smailee_dev; prod: Amvera Postgres через DATABASE_URL)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Пользователь (владелец аккаунта, self-serve) ──
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  companyName  String?
  createdAt    DateTime @default(now())

  // роль: клиент или админ сервиса
  role         UserRole @default(CLIENT)
  // тарифный план и срок его действия
  plan          Plan     @default(TRIAL)
  planExpiresAt DateTime?
  // принятие пользовательского соглашения (обязательно при регистрации/оплате)
  acceptedTermsAt DateTime?

  // Онбординг: чем занимается бизнес клиента (AI изучает это)
  websiteUrl   String?
  offer        String?  // ценностное предложение / оффер
  targetAudience String? // портрет клиента, кого ищем

  // Режим модерации ИИ-ответов (ТЗ §5.5): пока true — ответ ИИ на входящее
  // письмо сохраняется черновиком (ReplyMessage.status=DRAFT) и ждёт одобрения
  // оператора, а не уходит сразу. Default true — безопасное поведение на пилотах.
  aiModerationEnabled Boolean @default(true)

  // Онбординг-визард (UX TO BE, R2): когда пользователь закрыл визард
  // крестиком (или прошёл до конца). null = визард ещё показывается с /app.
  setupClosedAt DateTime?

  // Брендинг писем (R3): один фирменный цвет (кнопки/акценты HTML-шаблонов)
  // и URL логотипа для шапки письма. null = дефолтный вид шаблонов.
  brandColor   String?
  brandLogoUrl String?
  // Расширение брендинга: шрифт и подпись клиента. Пусто — письмо рендерится
  // НЕЙТРАЛЬНО (системный шрифт, серые акценты), но никогда в цветах/логотипе
  // Smailee: письмо идёт от имени клиента, наш бренд в нём неуместен.
  brandFont      String?
  brandSignature String?  // подпись в конце письма: имя, должность, контакты

  // Инструкция ИИ, как вести переписку по воронке (§5.5): тон, что предлагать,
  // куда вести, что не обещать. Подставляется в промпт генерации ответа.
  // Может быть составлена ИИ из загруженной выгрузки реальных диалогов.
  funnelPrompt String?

  mailboxes    Mailbox[]
  domainGroups DomainGroup[]
  contacts   Contact[]
  campaigns  Campaign[]
  leads      Lead[]      @relation("UserLeads")
  templates  EmailTemplate[]
  suppressions Suppression[]
  payments   Payment[]
  setupRequests SetupRequest[]
  imageGenerations ImageGeneration[]
}

/**
 * Сгенерированная через fal.ai картинка для письма. Хранится не ради галереи,
 * а ради ЛИМИТА: 10 генераций в сутки на клиента (внешний платный API).
 * Счёт ведётся по строкам за последние 24 часа — отдельный счётчик с датой
 * сбрасывать не нужно, а история заодно позволяет переиспользовать картинку.
 */
model ImageGeneration {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  prompt    String
  url       String
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

enum UserRole {
  CLIENT
  ADMIN
}

enum Plan {
  TRIAL
  START
  PRO
}

// ── Платёж (ЮMoney или другой шлюз) ──
model Payment {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider    String   // yoomoney | manual | ...
  externalId  String?  // id операции в платёжном шлюзе
  amount      Int      // в копейках
  plan        Plan     // какой план оплачен
  status      PaymentStatus @default(PENDING)
  createdAt   DateTime @default(now())
  confirmedAt DateTime?

  @@index([userId])
  @@index([externalId])
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  FAILED
}

// ── Ящик (Mailbox) — единица отправки/приёма: логин@домен с IMAP+SMTP ──
// Провайдер-агностичен: provider — только подсказка для UI, логика ветвится по
// профилю host/port/security (см. src/lib/mail/profiles.ts), не по этому полю.
model Mailbox {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  email       String
  senderName  String   // отображаемое имя отправителя (Sender Name)
  provider    MailProvider @default(yandex)

  // SMTP / IMAP доступы (host/port/security подставляются из профиля провайдера)
  smtpHost    String
  smtpPort    Int
  smtpSecurity MailSecurity @default(SSL)
  smtpLogin   String
  imapHost    String
  imapPort    Int
  imapSecurity MailSecurity @default(SSL)
  imapLogin   String
  // Пароли SMTP/IMAP — только зашифрованные (AES-256-GCM, src/lib/crypto.ts).
  // В открытом виде в БД не храним (ТЗ §8.2).
  smtpPasswordEnc String
  imapPasswordEnc String

  domainGroupId String
  domainGroup   DomainGroup @relation(fields: [domainGroupId], references: [id], onDelete: Cascade)

  // счётчик ХОЛОДНОЙ отправки (лимит 30/день на ящик, ТЗ §1.4)
  coldDailyLimit Int      @default(30)
  coldSentToday  Int      @default(0)
  coldSentDate   DateTime?

  // ОТДЕЛЬНЫЙ счётчик ПРОГРЕВА (в лимит 30 не входит, ТЗ §5.6).
  warmupSentToday Int      @default(0)
  warmupSentDate  DateTime?
  warmupDay       Int      @default(0)   // текущая ступень ramp
  warmupState     WarmupState @default(off)
  warmupStartedAt DateTime?
  // Наш посевной ящик (ТЗ §5.6, §9.1) — заводится оператором вне кода, но
  // помечается этим флагом, чтобы движок прогрева всегда включал его в пиринг
  // независимо от userId (кросс-клиентская сеть) и без 14-дневного ramp-гейта.
  isSeed          Boolean  @default(false)
  // Имя папки "Спам" на IMAP-сервере — резолвится из профиля провайдера
  // (см. src/lib/mail/profiles.ts), как host/port, чтобы движок прогрева не
  // ветвился по provider при спасении писем из спама (§5.6).
  spamFolder      String   @default("Спам")

  connState   MailboxConnState @default(paused) // ok | auth_error | unreachable | paused | disabled
  connError   String?          // причина ошибки подключения (для подсветки в UI)
  // Скоринг здоровья (§5.8, M5) — пересчитывается computeFleetHealth (worker
  // tick) из реальных сигналов M1–M4 (доля FAILED-отправок, connState).
  // Только для отображения на дашборде — саму ротацию исключает connState.
  healthScore Int      @default(100)
  // Причина авто- или ручной паузы (connState=disabled) — человекочитаемо,
  // для дашборда флота (§5.8). Null, если ящик не приостановлен по здоровью.
  pausedReason String?
  lastCheckedAt   DateTime?
  lastValidatedAt DateTime?
  createdAt   DateTime @default(now())

  // ── Позиция IMAP-поллинга (ТЗ §5.4, M3) ──
  // UIDVALIDITY эпохи INBOX + последний обработанный UID в ней. Нужны для
  // инкрементального опроса (не перечитывать весь ящик каждый тик) и чтобы не
  // поднимать старую переписку как "новые ответы" при первом подключении
  // (baseline на текущий UIDNEXT при первом опросе).
  imapUidValidity Int?
  imapLastUid     Int      @default(0)

  messages    Message[]
  warmupSent     WarmupEvent[] @relation("WarmupSender")
  warmupReceived WarmupEvent[] @relation("WarmupRecipient")

  @@unique([userId, email])
  @@index([domainGroupId])
}

// ── Домен-группа: все ящики на одном домене; на неё лимит 120/день (ТЗ §4.2) ──
model DomainGroup {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  domain      String
  dailyLimit  Int      @default(120) // лимит холодных на домен в день (ТЗ §1.4)
  sentToday   Int      @default(0)
  sentTodayDate DateTime?
  createdAt   DateTime @default(now())

  mailboxes   Mailbox[]

  @@unique([userId, domain])
}

// ── Событие сети прогрева (ТЗ §4.4, §5.6): одно письмо между двумя ящиками
// пула (нашими или чужими прогреваемыми/посевными). НЕ связано с Campaign/
// Message клиента — служебный трафик, в реальный инбокс не попадает.
model WarmupEvent {
  id                 String   @id @default(cuid())
  senderMailboxId    String
  senderMailbox      Mailbox  @relation("WarmupSender", fields: [senderMailboxId], references: [id], onDelete: Cascade)
  recipientMailboxId String
  recipientMailbox   Mailbox  @relation("WarmupRecipient", fields: [recipientMailboxId], references: [id], onDelete: Cascade)

  // Скрытый маркер (§5.6) — НЕ заголовок, зашит в тело письма (невидимый
  // span). По нему детектор (warmupDetector.ts) отличает прогрев от реального
  // ответа лида при IMAP-поллинге (inboundEngine.ts, M3-хук).
  code    String @unique
  subject String

  status WarmupEventStatus @default(sent)

  messageIdHeader String? // Message-ID отправленного письма (для тредов/ответов)
  recipientUid    Int?    // UID письма у получателя (найден при поллинге) — чтобы
                          // проход вовлечённости (read/reply/flag) бил по IMAP
                          // напрямую, без повторного поиска
  // если это письмо — ответ в рамках прогревочного треда, code родительского события
  repliedToCode String?
  // id узла корпуса (§5.9.3), которым сгенерировано это письмо — нужен, чтобы
  // при ответе выбрать дочерний узел (opener->response->continuation)
  corpusNodeId String?
  // глубина треда: 0 = opener, 1 = response, 2 = continuation (ограничивает
  // многоходовость — движок вовлечённости не отвечает глубже §5.6)
  hop Int @default(0)

  createdAt   DateTime  @default(now())
  deliveredAt DateTime?
  seenAt      DateTime?
  respondedAt DateTime?
  rescuedAt   DateTime?

  @@index([senderMailboxId])
  @@index([recipientMailboxId])
  @@index([status])
}

enum WarmupEventStatus {
  sent
  delivered
  opened
  replied
  rescued_from_spam
  failed
}

enum MailProvider {
  yandex
  google
  other
  custom
}

enum MailSecurity {
  SSL
  STARTTLS
}

enum WarmupState {
  off
  warming
  warm
}

enum MailboxConnState {
  ok
  auth_error
  unreachable
  paused
  // Авто- или вручную приостановлен мониторингом здоровья флота (§5.8, M5).
  // НЕ входит ни в один allow-list ("ok"/"paused") движков M2–M4 — ящик
  // выпадает из отправки/приёма/прогрева без единой правки их кода.
  // Отличается от "paused" (= только что подключён, ждёт первого успеха):
  // тот остаётся в ротации, чтобы иметь шанс подтвердить логин.
  disabled
}

// ── Контакт из базы клиента ──
model Contact {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  email      String
  name       String?
  company    String?
  segment    String?  // сегмент/ниша
  meta       Json?
  status     ContactStatus @default(ACTIVE)
  // результат валидации email при загрузке
  emailValid Boolean  @default(true)
  createdAt  DateTime @default(now())

  messages   Message[]

  @@unique([userId, email])
  @@index([userId, segment])
}

enum ContactStatus {
  ACTIVE
  BOUNCED
  UNSUBSCRIBED
  INVALID
  COMPLAINED
}

// ── Библиотека HTML-шаблонов писем ──
model EmailTemplate {
  id         String   @id @default(cuid())
  userId     String?  // null = системный (пресет), иначе — пользовательский
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  category   String   // announce | digest | promo | outreach | custom
  subject    String
  html       String   // HTML-тело с переменными {{name}} и т.п.
  isPreset   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@index([userId])
}

// ── Кампания рассылки ──
model Campaign {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  subject    String
  body       String   // текст/HTML письма (основной вариант / вариант A)
  isHtml     Boolean  @default(false)
  // A/B: необязательный второй вариант
  subjectB   String?
  bodyB      String?
  abEnabled  Boolean  @default(false)
  segment    String?
  // Пачка кампаний, созданных одним прогоном мастера по нескольким сегментам:
  // на каждый сегмент — своя кампания (свой текст, своя статистика), но
  // запускаются и показываются вместе. null = обычная одиночная кампания.
  batchId    String?
  status     CampaignStatus @default(DRAFT)
  scheduledAt DateTime?      // отложенный запуск (send_at)
  // R4: «Запустить после прогрева» — вместо красной ошибки при непрогретых
  // ящиках кампания ждёт (status=SCHEDULED, scheduledAt=null), и воркер сам
  // стартует её, когда у клиента появится первый ящик warmupState=warm.
  launchAfterWarmup Boolean @default(false)
  // follow-up: доп. письмо, если нет ответа через N дней
  followupEnabled Boolean @default(false)
  followupDays    Int     @default(3)
  followupSubject String?
  followupBody    String?
  createdAt  DateTime @default(now())
  startedAt  DateTime?

  // NB: кампания раскидывается по ПУЛУ ящиков (ТЗ §5.3), поэтому единого
  // отправителя у неё нет — ящик назначается на каждое Message при отправке (M2).

  messages   Message[]

  @@index([userId, batchId])
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  QUEUED
  SENDING
  SENT
  PAUSED
}

// ── Каждое отправленное письмо = отдельная запись со статусом ──
model Message {
  id          String   @id @default(cuid())
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contactId   String
  contact     Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  subject     String
  body        String
  isHtml      Boolean  @default(false)
  variant     String   @default("A")  // A | B (для A/B)
  step        Int      @default(0)     // 0 = основное, 1+ = follow-up
  status      MessageStatus @default(PENDING)
  providerMessageId String?
  sentAt      DateTime?
  deliveredAt DateTime?
  openedAt    DateTime?
  clickedAt   DateTime?
  repliedAt   DateTime?
  followupSentAt DateTime?  // когда отправлен follow-up для этого письма
  error       String?
  createdAt   DateTime @default(now())

  // ── Модель C: через какой ящик отправлено (для непрерывности треда и лимитов) ──
  // Назначается движком отправки M2; в M1 остаётся null.
  mailboxId   String?
  mailbox     Mailbox? @relation(fields: [mailboxId], references: [id])

  // Поля связывания входящего ответа с исходящим (фундамент диалога, IMAP M3):
  messageIdHeader String?  // Message-ID отправленного письма
  inReplyTo       String?  // In-Reply-To входящего
  threadRefs      String?  // References (цепочка Message-ID)
  threadAddress   String?  // адрес треда (reply+<id>@…) — если используется

  events      Event[]
  thread      ReplyMessage[]
  lead        Lead?

  @@index([campaignId, status])
  @@index([mailboxId])
}

enum MessageStatus {
  PENDING
  QUEUED
  SENT
  DELIVERED
  OPENED
  CLICKED
  REPLIED
  BOUNCED
  FAILED
}

// ── Сырые события (open/click/bounce/reply) для аналитики ──
model Event {
  id        String   @id @default(cuid())
  messageId String
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  type      String   // open | click | bounce | reply | delivered | complaint
  payload   Json?
  createdAt DateTime @default(now())

  @@index([messageId, type])
}

// ── Диалог: входящие ответы + AI-ответы (email-тред) ──
model ReplyMessage {
  id         String   @id @default(cuid())
  messageId  String
  message    Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  direction  String   // inbound (от клиента) | outbound (AI-ответ)
  subject    String?  // тема письма (Re: ...)
  fromEmail  String?
  toEmail    String?
  body       String
  isAi       Boolean  @default(false)
  createdAt  DateTime @default(now())

  // Режим модерации (ТЗ §5.5): outbound AI-ответ создаётся со статусом DRAFT,
  // если у клиента включена модерация — реально не отправлен, ждёт оператора
  // (approveAndSendReply). SENT — либо отправлено сразу (модерация выключена),
  // либо после одобрения. Для inbound всегда SENT (это не наша отправка).
  status ReplyMessageStatus @default(SENT)
  // Message-ID входящего письма (для идемпотентности при повторном поллинге
  // и как материал для In-Reply-To будущих ответов в этом треде).
  externalMessageId String?
  // Message-ID реально отправленного AI-ответа (от sendViaMailbox), по
  // аналогии с Message.providerMessageId.
  providerMessageId String?

  @@index([messageId])
  @@index([externalMessageId])
}

enum ReplyMessageStatus {
  DRAFT
  SENT
}

// ── Квалифицированный лид ──
model Lead {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation("UserLeads", fields: [userId], references: [id], onDelete: Cascade)
  messageId    String   @unique
  message      Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  qualification LeadQualification @default(UNKNOWN)
  summary      String?
  pushedToCrm  Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([userId, qualification])
}

enum LeadQualification {
  HOT
  COLD
  IRRELEVANT
  UNKNOWN
}

// ── Suppression-список: отписки, жалобы, невалидные (не слать) ──
model Suppression {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  email     String
  reason    String   // unsubscribed | complained | bounced | manual
  createdAt DateTime @default(now())

  @@unique([userId, email])
  @@index([userId])
}

// ── Заявка «Настройте всё за меня» (онбординг-визард, R2) ──
// Пока уходит письмом оператору (config.setupNotifyEmail) + видна в админке;
// позже — интеграция с CRM.
model SetupRequest {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  contact       String   // телефон / telegram / email — как удобно клиенту
  preferredTime String?
  createdAt     DateTime @default(now())

  @@index([userId])
}

// ── Заявка с лендинга (лид-форма / запись на демо) ──
model LandingLead {
  id        String   @id @default(cuid())
  name      String
  email     String
  messenger String?
  company   String?
  source    String?  // utm/канал
  createdAt DateTime @default(now())
}
