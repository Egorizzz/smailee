// Smailee — схема БД
// Postgres (dev: локальный smailee_dev; prod: Amvera Postgres через DATABASE_URL)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Пользователь (владелец аккаунта, self-serve) ──
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  companyName  String?
  createdAt    DateTime @default(now())

  // роль: клиент или админ сервиса
  role         UserRole @default(CLIENT)
  // тарифный план и срок его действия
  plan          Plan     @default(TRIAL)
  planExpiresAt DateTime?
  // принятие пользовательского соглашения (обязательно при регистрации/оплате)
  acceptedTermsAt DateTime?

  // Онбординг: чем занимается бизнес клиента (AI изучает это)
  websiteUrl   String?
  offer        String?  // ценностное предложение / оффер
  targetAudience String? // портрет клиента, кого ищем

  // ── Изоляция в Unisender Go: отдельный Project на клиента ──
  // API-ключ Project'а этого клиента в Unisender Go (заводится вручную в ЛК
  // Unisender админом, см. docs/unisender-project-setup.md — Project API
  // по умолчанию отключён у Unisender, включается только по запросу в
  // техподдержку). Пока не задан — отправка и проверка домена идут через общий
  // аккаунт (UNISENDER_API_KEY из .env), см. src/lib/services/unisender.ts.
  unisenderApiKey String?

  senders    Sender[]
  contacts   Contact[]
  campaigns  Campaign[]
  leads      Lead[]      @relation("UserLeads")
  templates  EmailTemplate[]
  suppressions Suppression[]
  payments   Payment[]
}

enum UserRole {
  CLIENT
  ADMIN
}

enum Plan {
  TRIAL
  START
  PRO
}

// ── Платёж (ЮMoney или другой шлюз) ──
model Payment {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider    String   // yoomoney | manual | ...
  externalId  String?  // id операции в платёжном шлюзе
  amount      Int      // в копейках
  plan        Plan     // какой план оплачен
  status      PaymentStatus @default(PENDING)
  createdAt   DateTime @default(now())
  confirmedAt DateTime?

  @@index([userId])
  @@index([externalId])
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  FAILED
}

// ── Отправитель (домен/почта, с которой шлём) ──
model Sender {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromEmail  String
  fromName   String
  domain     String   @unique  // глобально уникален: для MANAGED = <slug>.smailee.ru, для OWN = домен клиента
  // MANAGED = поддомен на нашем smailee.ru (DNS настраиваем мы, клиент ничего не делает).
  // OWN = собственный домен клиента (клиент прописывает DNS; доступно на тарифе PRO).
  kind       SenderKind @default(MANAGED)
  // статус проверки DNS
  spfOk      Boolean  @default(false)
  dkimOk     Boolean  @default(false)
  dmarcOk    Boolean  @default(false)
  verified   Boolean  @default(false)
  // прогрев (warm-up): текущий дневной лимит и счётчик
  warmupDay      Int    @default(0)   // сколько дней идёт прогрев
  dailyLimit     Int    @default(30)  // текущий лимит писем в день
  sentToday      Int    @default(0)
  sentTodayDate  DateTime?
  createdAt  DateTime @default(now())

  campaigns  Campaign[]
}

enum SenderKind {
  MANAGED
  OWN
}

// ── Контакт из базы клиента ──
model Contact {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  email      String
  name       String?
  company    String?
  segment    String?  // сегмент/ниша
  meta       Json?
  status     ContactStatus @default(ACTIVE)
  // результат валидации email при загрузке
  emailValid Boolean  @default(true)
  createdAt  DateTime @default(now())

  messages   Message[]

  @@unique([userId, email])
  @@index([userId, segment])
}

enum ContactStatus {
  ACTIVE
  BOUNCED
  UNSUBSCRIBED
  INVALID
  COMPLAINED
}

// ── Библиотека HTML-шаблонов писем ──
model EmailTemplate {
  id         String   @id @default(cuid())
  userId     String?  // null = системный (пресет), иначе — пользовательский
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  category   String   // announce | digest | promo | outreach | custom
  subject    String
  html       String   // HTML-тело с переменными {{name}} и т.п.
  isPreset   Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([userId])
}

// ── Кампания рассылки ──
model Campaign {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  senderId   String?
  sender     Sender?  @relation(fields: [senderId], references: [id])
  name       String
  subject    String
  body       String   // текст/HTML письма (основной вариант / вариант A)
  isHtml     Boolean  @default(false)
  // A/B: необязательный второй вариант
  subjectB   String?
  bodyB      String?
  abEnabled  Boolean  @default(false)
  segment    String?
  status     CampaignStatus @default(DRAFT)
  scheduledAt DateTime?      // отложенный запуск (send_at)
  // follow-up: доп. письмо, если нет ответа через N дней
  followupEnabled Boolean @default(false)
  followupDays    Int     @default(3)
  followupSubject String?
  followupBody    String?
  createdAt  DateTime @default(now())
  startedAt  DateTime?

  // ── Контент-маркетинг: серия писем (type = SERIES) ──
  type                CampaignType @default(BLAST)
  seriesTopic         String?      // тема серии, задаёт пользователь ("банкротство")
  seriesFrequencyDays Int?         // раз в сколько дней уходит следующее письмо серии
  seriesTotalSteps    Int?         // сколько писем в серии всего

  messages   Message[]
  contentSteps ContentStep[]
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  QUEUED
  SENDING
  SENT
  PAUSED
}

enum CampaignType {
  BLAST   // разовая рассылка (как раньше)
  SERIES  // контент-маркетинг: серия писем по расписанию
}

// ── Один шаг серии контент-маркетинга: "мастер"-контент, из которого при
// наступлении dayOffset материализуются Message на каждый ACTIVE-контакт
// сегмента (аналогично тому, как follow-up создаёт Message step=1). ──
model ContentStep {
  id          String   @id @default(cuid())
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  stepIndex   Int      // 0, 1, 2 ... порядок в серии
  topic       String   // конкретная тема письма, напр. "Что делать при банкротстве"
  angle       String   // ракурс/цель письма, для контекста при генерации и в UI-превью
  dayOffset   Int      // через сколько дней после старта серии слать (0 = сразу)
  includeCta  Boolean  @default(false) // показывать кнопку "Оставить заявку"
  ctaLabel    String?  // текст кнопки, если includeCta
  subject     String?  // заполняется после генерации контента
  body        String?  // готовый HTML (с вставленной картинкой), после генерации
  imagePrompt String?  // промпт для fal.ai, который написал DeepSeek
  imageUrl    String?  // URL картинки, полученной от fal.ai
  status      ContentStepStatus @default(DRAFT)
  sentAt      DateTime? // когда материализованы Message для этого шага
  createdAt   DateTime @default(now())

  messages    Message[]

  @@unique([campaignId, stepIndex])
}

enum ContentStepStatus {
  DRAFT  // только план (тема/ракурс), текст ещё не сгенерирован
  READY  // текст + картинка готовы, можно слать
  SENT   // Message материализованы для всех контактов сегмента
}

// ── Каждое отправленное письмо = отдельная запись со статусом ──
model Message {
  id          String   @id @default(cuid())
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contactId   String
  contact     Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  subject     String
  body        String
  isHtml      Boolean  @default(false)
  variant     String   @default("A")  // A | B (для A/B)
  step        Int      @default(0)     // 0 = основное, 1+ = follow-up
  status      MessageStatus @default(PENDING)
  providerMessageId String?
  sentAt      DateTime?
  deliveredAt DateTime?
  openedAt    DateTime?
  clickedAt   DateTime?
  repliedAt   DateTime?
  followupSentAt DateTime?  // когда отправлен follow-up для этого письма
  error       String?
  createdAt   DateTime @default(now())

  // ── Контент-маркетинг ──
  contentStepId   String?      // если письмо материализовано из шага серии
  contentStep     ContentStep? @relation(fields: [contentStepId], references: [id])
  isPersonalNudge Boolean      @default(false) // авто-персональное касание (высокий open rate)

  events      Event[]
  thread      ReplyMessage[]
  lead        Lead?

  @@index([campaignId, status])
  @@index([contentStepId])
}

enum MessageStatus {
  PENDING
  QUEUED
  SENT
  DELIVERED
  OPENED
  CLICKED
  REPLIED
  BOUNCED
  FAILED
}

// ── Сырые события (open/click/bounce/reply) для аналитики ──
model Event {
  id        String   @id @default(cuid())
  messageId String
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  type      String   // open | click | bounce | reply | delivered | complaint
  payload   Json?
  createdAt DateTime @default(now())

  @@index([messageId, type])
}

// ── Диалог: входящие ответы + AI-ответы (email-тред) ──
model ReplyMessage {
  id         String   @id @default(cuid())
  messageId  String
  message    Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  direction  String   // inbound (от клиента) | outbound (AI-ответ)
  subject    String?  // тема письма (Re: ...)
  fromEmail  String?
  toEmail    String?
  body       String
  isAi       Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([messageId])
}

// ── Квалифицированный лид ──
model Lead {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation("UserLeads", fields: [userId], references: [id], onDelete: Cascade)
  messageId    String   @unique
  message      Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  qualification LeadQualification @default(UNKNOWN)
  summary      String?
  pushedToCrm  Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([userId, qualification])
}

enum LeadQualification {
  HOT
  COLD
  IRRELEVANT
  UNKNOWN
}

// ── Suppression-список: отписки, жалобы, невалидные (не слать) ──
model Suppression {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  email     String
  reason    String   // unsubscribed | complained | bounced | manual
  createdAt DateTime @default(now())

  @@unique([userId, email])
  @@index([userId])
}

// ── Лог генераций картинок через fal.ai — учёт бюджета (см. DECISIONS.md) ──
model ImageGeneration {
  id        String   @id @default(cuid())
  userId    String?
  prompt    String
  imageUrl  String?
  mocked    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// ── Заявка с лендинга (лид-форма / запись на демо) ──
model LandingLead {
  id        String   @id @default(cuid())
  name      String
  email     String
  messenger String?
  company   String?
  source    String?  // utm/канал
  createdAt DateTime @default(now())
}
