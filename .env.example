# === Smailee — пример переменных окружения ===
# Скопируй в .env и заполни реальными значениями:  cp .env.example .env

# fal.ai (генерация изображений)
FAL_KEY=
# Максимум реальных генераций картинок через fal.ai (см. DECISIONS.md)
FAL_IMAGE_BUDGET=50

# Claude / Anthropic (генерация писем, диалог, квалификация) — пока в UI "Скоро"
ANTHROPIC_API_KEY=

# DeepSeek (основной LLM-провайдер на время теста)
DEEPSEEK_API_KEY=

# Unisender Go (отправка email)
UNISENDER_API_KEY=

# База данных (Postgres)
DATABASE_URL=

# Битрикс24 (передача лидов)
BITRIX24_WEBHOOK_URL=

# Секрет для подписи сессий (в проде — длинная случайная строка)
JWT_SECRET=

# Публичный URL приложения (для пикселей открытий, трекинга кликов, ссылок отписки)
# Локально: http://localhost:3000 ; на проде: https://<app>.amvera.io
APP_URL=http://localhost:3000

# Email администратора: аккаунт с этим email получает роль ADMIN при регистрации
ADMIN_EMAIL=

# Секрет вебхука входящих писем (настраивается у email-провайдера)
INBOUND_SECRET=

# Секрет вебхука платёжного шлюза (ЮMoney и т.п.)
PAYMENT_WEBHOOK_SECRET=
