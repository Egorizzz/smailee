# === Smailee — пример переменных окружения ===
# Скопируй в .env и заполни реальными значениями:  cp .env.example .env

# fal.ai (генерация изображений)
FAL_KEY=

# Claude / Anthropic (генерация писем, диалог, квалификация)
ANTHROPIC_API_KEY=

# Unisender Go (отправка email)
UNISENDER_API_KEY=

# База данных (Postgres)
DATABASE_URL=

# Битрикс24 (передача лидов)
BITRIX24_WEBHOOK_URL=

# Секрет для подписи сессий (в проде — длинная случайная строка)
JWT_SECRET=

# Публичный URL приложения (для пикселей открытий, трекинга кликов, ссылок отписки)
# Локально: http://localhost:3000 ; на проде: https://<app>.amvera.io
APP_URL=http://localhost:3000
